# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=localia
DB_PASSWORD=localia_dev_password
DB_NAME=localia_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Meilisearch (Algolia alternative)
MEILI_HOST=localhost
MEILI_PORT=7700
MEILI_MASTER_KEY=localia_dev_master_key

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Application
NODE_ENV=development
PORT=3000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Better Auth
BETTER_AUTH_URL=http://localhost:3000

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Email (Resend)
RESEND_API_KEY=re_xxxxx_your_resend_api_key
RESEND_FROM_EMAIL=Localia <noreply@localia.com>
